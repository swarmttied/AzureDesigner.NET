<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AzureDesigner.WinUI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AzureDesigner.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AzureDesigner.WinUI.Models"
    xmlns:coremodels="using:AzureDesigner.Models"
    xmlns:conv="using:CommunityToolkit.WinUI.Converters"
    xmlns:sys="using:System"
    xmlns:ctrls="using:AzureDesigner.WinUI.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BoolNegationConverter x:Key="BoolNegationConverter"/>
    </Page.Resources>

    <!-- Theme Reources-->
    <!-- https://wpfui.lepo.co/api/Wpf.Ui.Markup.ThemeResource.html -->


    <Grid x:Name="rootGrid" Grid.Row="1" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" MinWidth="750" />
            <ColumnDefinition Width="750" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"  />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <Border x:Name="titleBar" Grid.ColumnSpan="3" Margin="-10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <TextBlock Margin="5,5,5,0"
                       Text="Azure Insight Studio"
                       HorizontalAlignment="Stretch"
                       TextAlignment="Left"
                       Style="{ThemeResource BodyLargeTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        </Border>

        <InfoBar Grid.Row="1" Grid.ColumnSpan="3"  IsOpen="{x:Bind ViewModel.IsNotBusy, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" 
                   Title="Busy" Message="{x:Bind ViewModel.InfoBarText, Mode=OneWay}" Severity="Informational" Margin="5"/>

        <Border CornerRadius="10" Grid.Row="2" Grid.Column="1" Margin="0,5,5,0" BorderThickness="1" 
                BorderBrush="{ThemeResource SystemColorGrayTextBrush}">
            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="By the numbers" Style="{ThemeResource TitleTextBlockStyle }" Grid.ColumnSpan="2" Margin="15,10,10,10" />
                <TextBlock Text="Subscriptions" Grid.Row="1"   Margin="15,5,0,2"/>
                <TextBlock Text="{x:Bind ViewModel.SubscriptionCount, Mode=OneWay}" Grid.Row="1" Grid.Column="1" Margin="0,5,0,2" HorizontalAlignment="Right"/>
                <TextBlock Text="Resources " Grid.Row="2"      Margin="15,5,0,2"/>
                <TextBlock Text="{x:Bind ViewModel.ResourceCount, Mode=OneWay}" Grid.Row="2" Grid.Column="1" Margin="0,5,0,2" HorizontalAlignment="Right"/>
                <TextBlock Text="Traced " Grid.Row="3"         Margin="15,5,0,2" />                
                <TextBlock Text="{x:Bind ViewModel.TracedCount, Mode=OneWay}" Grid.Row="3" Grid.Column="1" Margin="0,5,0,2" HorizontalAlignment="Right"/> 
                <TextBlock Text="Analyzed  " Grid.Row="5"       Margin="15,5,0,2"/>
                <TextBlock Text="{x:Bind ViewModel.AnalyzedCount, Mode=OneWay}" Grid.Row="5" Grid.Column="1" Margin="0,5,0,2" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border CornerRadius="10" Grid.Row="2" Grid.Column="2" Margin="0,5,0,0" BorderThickness="1" 
         BorderBrush="{ThemeResource SystemColorGrayTextBrush}">
            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </Border>

        <StackPanel Orientation="Vertical" Grid.Row="2">
            <TextBlock Text="Select subscription" VerticalAlignment="Stretch" Margin="0,5,5,0"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.Subscriptions, Mode=OneWay}" 
              SelectedItem="{x:Bind ViewModel.Subscription, Mode=TwoWay}" 
              VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
              Margin="0,5,5,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="coremodels:Subscription">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{x:Bind Name}" Margin="0,0,0,2"/>
                            <TextBlock Text="{x:Bind Id}" Foreground="Gray" FontSize="10"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Fetch resources" Command="{x:Bind ViewModel.LoadDataCommand}" Margin="0,5,5,0" IsEnabled="{x:Bind ViewModel.IsNotBusy, Mode=OneWay}"/>
            <CheckBox Margin="0,5,5,0" IsChecked="{x:Bind ViewModel.AppsOnly, Mode=TwoWay}">
                <TextBlock Text="Apps only (overrides resource type filter)" />
            </CheckBox>
            <TextBlock Text="Select resource type" VerticalAlignment="Stretch" Margin="0,5,5,0"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.ServiceTypes, Mode=TwoWay}" SelectedItem="{x:Bind ViewModel.SelectedServiceType, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" Margin="0,5,5,5">               
            </ComboBox>
        </StackPanel>

        <Border CornerRadius="10"  Margin="0,5,5,0" Grid.Row="3">
            <ScrollViewer   HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
                <TreeView x:Name="treeView" ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" Grid.Row="3" SelectedItem="{x:Bind ViewModel.SelectedService, Mode=TwoWay}"                  
                  Background="{ThemeResource ControlElevationBorderBrush }">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:NodeViewModel">
                            <TreeViewItem ItemsSource="{x:Bind Dependencies, Mode=OneWay}">
                                <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="32" Height="32" Source="{x:Bind IconPath}" />
                                            <TextBlock Text="{x:Bind Name}"  Margin="12,20,12,20" />
                                            <TextBlock Text="Traced" Foreground="Green" FontWeight="Bold" Margin="0,22,12,0" Visibility="{x:Bind IsTraced, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <Button Content="..." Margin="0,5,0,0" Height="30" Tag="{x:Bind}" Click="TreeViewButton_Click">
                                                <Button.Flyout>
                                                    <Flyout>
                                                        <StackPanel>
                                                            <!--<TextBlock Style="{ThemeResource BaseTextBlockStyle}" Text="" Margin="0,0,0,12" />-->
                                                            <Button Content="Analyze" 
                                                    Command="{Binding GetDependenciesCommand}"
                                                    IsEnabled="{Binding EnableGetDependencies, Mode=TwoWay}"/>
                                                            <HyperlinkButton NavigateUri="{x:Bind PortalUrl}" Content="Open in portal"/>
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind TypeFriendlyName}" Foreground="Gray" Margin="32,0,0,0"/>
                                </StackPanel>
                            </TreeViewItem>

                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Grid.Row="3" Margin="0,5,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="125"/>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*" />               
            </Grid.ColumnDefinitions>
            <TextBlock Text="Name" Grid.Row="0" Grid.Column="0" Margin="5,5,5,0"/>
            <TextBox Text="{x:Bind ViewModel.SelectedService.Name, Mode=OneWay}" Grid.Row="0" Grid.Column="1" Margin="5,5,5,0"/>
            <TextBlock Text="Type" Grid.Row="1" Grid.Column="0" Margin="5,5,5,0"/>
            <TextBox Text="{x:Bind ViewModel.SelectedService.Type, Mode=OneWay}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,0"/>
            <TextBlock Text="Resource Group" Grid.Row="2" Grid.Column="0" Margin="5,5,5,0"/>
            <TextBox Text="{x:Bind ViewModel.SelectedService.ResourceGroupName, Mode=OneWay}" Grid.Row="2" Grid.Column="1" Margin="5,5,5,0"/>
            <TextBlock Text="Location" Grid.Row="3" Grid.Column="0" Margin="5,5,5,0"/>
            <TextBox Text="{x:Bind ViewModel.SelectedService.Location, Mode=OneWay}" Grid.Row="3" Grid.Column="1" Margin="5"/>

            <!--<Button Grid.Row="4" Content="{x:Bind ViewModel.GetDependencyText, Mode=OneWay}" Command="{x:Bind ViewModel.GetDependenciesCommand}" 
                Grid.ColumnSpan="2" Margin="5,20,5,5" HorizontalAlignment="Left" Width="250" IsEnabled="{x:Bind ViewModel.EnableGetDependencies, Mode=OneWay}"/>-->

            <Border Grid.Row="5" Grid.ColumnSpan="4" Margin="5,20,5,0" CornerRadius="10">
                <TabView Grid.Row="5" Grid.ColumnSpan="4"  IsEnabled="{x:Bind ViewModel.EnableGetDependencies, Mode=OneWay}">
                    <TabViewItem Header="App Settings" Visibility="{x:Bind ViewModel.SettingsApplicable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox ItemsSource="{x:Bind ViewModel.SelectedService.Settings, Mode=OneWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="coremodels:Setting">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{x:Bind Key}" Width="350" Margin="0,0,5,0"/>
                                        <TextBox Text="{x:Bind Value}" Foreground="Gray" IsReadOnly="True"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                    </TabViewItem>
                    <!--<TabViewItem Header="Dependencies">
                        <ListBox ItemsSource="{x:Bind ViewModel.SelectedService.Dependencies, Mode=OneWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:NodeViewModel">
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <StackPanel Orientation="Horizontal">
                                            <HyperlinkButton NavigateUri="{x:Bind PortalUrl}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Width="16" Height="16" Source="{x:Bind IconPath}" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{x:Bind Name}" />
                                                </StackPanel>
                                            </HyperlinkButton>                                     
                                        </StackPanel>                                    
                                        <TextBlock Text="{x:Bind Type}" Foreground="Gray" Margin="32,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabViewItem>-->
                    <TabViewItem Header="Dependencies" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">                   
                        <ctrls:DependencyCanvas Node="{x:Bind ViewModel.SelectedService, Mode=OneWay}" x:Name="dependencyCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="720" Width="1000"/>
                    </TabViewItem>
                    <TabViewItem Header="Risks">
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="Fix All" Command="{x:Bind ViewModel.FixRisksCommand}" Margin="5" HorizontalAlignment="Left" 
                                    Visibility="{x:Bind ViewModel.CanFixRisk, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                            <ListBox Grid.Row="1" ItemsSource="{x:Bind ViewModel.SelectedService.Risks, Mode=OneWay}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                     SelectedItem="{x:Bind ViewModel.SelectedRisk, Mode=OneWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="coremodels:Risk">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="fixRioskButton" Content="Fix" IsEnabled="{Binding Fixed, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                                    Click="fixRioskButton_Click" Tag="{x:Bind}"/>
                                            <TextBlock Text="{x:Bind Description}" Margin="5" ToolTipService.ToolTip="{x:Bind Description}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabViewItem>
                    <TabViewItem Header="Issues">
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="Fix All" Command="{x:Bind ViewModel.FixIssuesCommand}" Margin="5" HorizontalAlignment="Left" 
                                    Visibility="{x:Bind ViewModel.CanFixIssues, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                            <ListBox Grid.Row="1" ItemsSource="{x:Bind ViewModel.SelectedService.Issues, Mode=OneWay}" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:DependencyIssuesViewModel">
                                        <Expander IsExpanded="False" Margin="5">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Width="16" Height="16" Source="{x:Bind Node.IconPath}" />
                                                    <TextBlock Text="{x:Bind Node.Name}"  Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Expander.Header>
                                            <ListBox ItemsSource="{x:Bind DependencyIssues.Issues, Mode=OneWay}" SelectedItem="{x:Bind SelectedIssue, Mode=OneWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="coremodels:Issue">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button x:Name="fixIssueButton" Content="Fix" IsEnabled="{Binding Fixed, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                                                    Click="fixIssueButton_Click" Tag="{x:Bind}"/>
                                                            <TextBlock Text="{x:Bind Description}" Margin="5" ToolTipService.ToolTip="{x:Bind Description}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Expander>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabViewItem>
                </TabView>
            </Border>

        </Grid>

        <Grid Grid.Column="2" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="AI Trace" FontWeight="Bold" Margin="0,0,0,5" Grid.Row="0" Style="{ThemeResource BodyLargeTextBlockStyle}"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <CheckBox IsChecked="{x:Bind ViewModel.ShowRequests, Mode=TwoWay}" Content="Requests" Grid.Column="0" Grid.Row="0" Margin="5,0,0,0"/>
                <CheckBox IsChecked="{x:Bind ViewModel.ShowResponses, Mode=TwoWay}" Content="Responces" Grid.Column="0" Grid.Row="1" Margin="5,3,0,0"/>
                <CheckBox IsChecked="{x:Bind ViewModel.ShowFunctionCalls, Mode=TwoWay}" Content="Function Calls" Grid.Column="0" Grid.Row="2" Margin="5,3,0,0"/>
                <CheckBox IsChecked="{x:Bind ViewModel.ShowRateLimits, Mode=TwoWay}" Content="Rate Limits" Grid.Column="0" Grid.Row="3" Margin="5,3,0,0"/>
                <CheckBox IsChecked="{x:Bind ViewModel.ShowExceptions, Mode=TwoWay}" Content="Exceptions" Grid.Column="0" Grid.Row="4" Margin="5,3,0,5"/>
            </Grid>
            <Border CornerRadius="10" Grid.Row="2">
                <ListBox x:Name="tracesListBox" ItemsSource="{x:Bind ViewModel.TraceMessages, Mode=OneWay}" Grid.Row="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:TraceMessage">
                            <StackPanel Orientation="Vertical" Margin="5">
                                <TextBlock Text="{x:Bind TimeStamp}" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="{x:Bind Text}" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind Type}" Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>


    </Grid>

</Page>
